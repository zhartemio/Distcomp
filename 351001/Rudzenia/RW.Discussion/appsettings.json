{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cassandra": {
    "ContactPoint": "localhost",
    "Port": "9042",
    "Keyspace": "distcomp"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "InTopic": "InTopic",
    "OutTopic": "OutTopic",
    "GroupId": "discussion-group"
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "KeyPrefix": "rw",
    "TtlSeconds": 300
  }
}
