                    "type": "string",
                    "example": "John"
                },
                "id": {
                    "type": "integer",
                    "example": 1
                },
                "lastname": {
                    "type": "string",
                    "example": "Doe"
                },
                "login": {
                    "type": "string",
                    "example": "john_doe"
                }
            }
        }
