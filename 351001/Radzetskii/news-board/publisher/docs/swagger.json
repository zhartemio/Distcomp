    "definitions": {
        "dto.ErrorResponse": {
            "type": "object",
            "properties": {
                "errorCode": {
                    "type": "string",
                    "example": "40401"
                },
                "errorMessage": {
                    "type": "string",
                    "example": "User not found"
                }
            }
        },
        "dto.MarkerRequestTo": {
            "type": "object",
            "required": [
                "name"
            ],
            "properties": {
                "name": {
                    "type": "string",
                    "maxLength": 32,
                    "minLength": 2,
                    "example": "urgent"
                }
            }
        },
        "dto.MarkerResponseTo": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "integer",
                    "example": 1
                },
                "name": {
                    "type": "string",
                    "example": "urgent"
                }
            }
        },
        "dto.NewsRequestTo": {
            "type": "object",
            "required": [
                "content",
                "title",
                "userId"
            ],
            "properties": {
                "content": {
                    "type": "string",
                    "maxLength": 2048,
                    "minLength": 4,
                    "example": "Some important content here..."
                },
                "markers": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "example": [
                        "red",
                        "green",
                        "blue"
                    ]
                },
                "title": {
                    "type": "string",
                    "maxLength": 64,
                    "minLength": 2,
                    "example": "Breaking News"
                },
                "userId": {
                    "type": "integer",
                    "minimum": 1,
                    "example": 1
                }
            }
        },
        "dto.NewsResponseTo": {
            "type": "object",
            "properties": {
                "content": {
                    "type": "string",
                    "example": "Some important content here..."
                },
                "created": {
                    "type": "string",
                    "example": "2023-01-01T00:00:00Z"
                },
                "id": {
                    "type": "integer",
                    "example": 1
                },
                "modified": {
                    "type": "string",
                    "example": "2023-01-01T00:00:00Z"
                },
                "title": {
                    "type": "string",
                    "example": "Breaking News"
                },
                "userId": {
                    "type": "integer",
                    "example": 1
                }
            }
        },
        "dto.NoticeRequestTo": {
            "type": "object",
            "required": [
                "content",
                "newsId"
            ],
            "properties": {
                "content": {
                    "type": "string",
                    "maxLength": 2048,
                    "minLength": 2,
