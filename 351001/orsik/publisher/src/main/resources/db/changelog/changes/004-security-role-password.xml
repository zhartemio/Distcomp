<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="004-add-creator-role" author="codex">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="tbl_creator" columnName="role"/>
            </not>
        </preConditions>
        <addColumn tableName="tbl_creator">
            <column name="role" type="VARCHAR(16)" defaultValue="CUSTOMER">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="004-normalize-creator-security-data" author="codex">
        <sql>UPDATE tbl_creator SET role = 'CUSTOMER' WHERE role IS NULL OR role = '';</sql>
        <sql>UPDATE tbl_creator SET password = '$2y$10$uciEAjjcxFmJWHJh7xu.r.Nx8h.BWSD7zlfl.6jWFxoOchI2a8RVe', role = 'ADMIN' WHERE login = 'orsik';</sql>
    </changeSet>
</databaseChangeLog>
