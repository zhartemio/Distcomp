<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">

    <!-- После lab3 в той же БД мог выполниться drop tbl_reaction; lab1-2 снова нужна таблица -->
    <changeSet id="20260404-lab12-restore-tbl-reaction" author="student">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="tbl_reaction"/>
            </not>
        </preConditions>
        <createTable tableName="tbl_reaction">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tweet_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_reaction_tweet" referencedTableName="tbl_tweet"
                             referencedColumnNames="id" deleteCascade="true"/>
            </column>
            <column name="content" type="VARCHAR(2048)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>
