DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=distcomp
DB_SCHEMA=distcomp

# Модуль discussion (Cassandra API)
DISCUSSION_BASE_URL=http://localhost:24130

# Kafka transport for Note entity
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_NOTES_REQUEST_TOPIC=notes.request
KAFKA_NOTES_REPLY_TOPIC=notes.reply
KAFKA_NOTES_PUBLISHER_GROUP_ID=publisher-notes-group
KAFKA_REQUEST_TIMEOUT_SECONDS=5.0
