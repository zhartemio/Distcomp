CASSANDRA_HOSTS=localhost
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=distcomp
# Число партиций для tbl_note_by_id: id_bucket = id % NOTE_ID_BUCKETS
NOTE_ID_BUCKETS=64

# Kafka transport for Note entity
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_NOTES_REQUEST_TOPIC=notes.request
KAFKA_NOTES_REPLY_TOPIC=notes.reply
KAFKA_NOTES_DISCUSSION_GROUP_ID=discussion-notes-group
