<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

  <changeSet id="1" author="distcomp">
    <createTable tableName="tbl_user">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="login" type="VARCHAR(64)">
        <constraints nullable="false" unique="true"/>
      </column>
      <column name="password" type="VARCHAR(128)">
        <constraints nullable="false"/>
      </column>
      <column name="firstname" type="VARCHAR(64)">
        <constraints nullable="false"/>
      </column>
      <column name="lastname" type="VARCHAR(64)">
        <constraints nullable="false"/>
      </column>
      <column name="role" type="VARCHAR(16)" defaultValue="CUSTOMER">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>

  <changeSet id="2" author="distcomp">
    <createTable tableName="tbl_article">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="title" type="VARCHAR(64)">
        <constraints nullable="false"/>
      </column>
      <column name="content" type="VARCHAR(2048)">
        <constraints nullable="false"/>
      </column>
      <column name="created" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
        <constraints nullable="false"/>
      </column>
      <column name="modified" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
        <constraints nullable="false"/>
      </column>
      <column name="userId" type="BIGINT">
        <constraints nullable="false"/>
      </column>
    </createTable>
    <addForeignKeyConstraint
      baseTableName="tbl_article"
      baseColumnNames="userId"
      referencedTableName="tbl_user"
      referencedColumnNames="id"
      constraintName="fk_article_user"/>
  </changeSet>

  <changeSet id="3" author="distcomp">
    <createTable tableName="tbl_marker">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="name" type="VARCHAR(32)">
        <constraints nullable="false" unique="true"/>
      </column>
    </createTable>
  </changeSet>

  <changeSet id="4" author="distcomp">
    <createTable tableName="tbl_notice">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="content" type="VARCHAR(2048)">
        <constraints nullable="false"/>
      </column>
      <column name="articleId" type="BIGINT">
        <constraints nullable="false"/>
      </column>
    </createTable>
  </changeSet>

  <changeSet id="5" author="distcomp">
    <createTable tableName="tbl_article_marker">
      <column name="article_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>
      <column name="marker_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>
    </createTable>
    <addPrimaryKey tableName="tbl_article_marker" columnNames="article_id, marker_id"/>
    <addForeignKeyConstraint
      baseTableName="tbl_article_marker"
      baseColumnNames="article_id"
      referencedTableName="tbl_article"
      referencedColumnNames="id"
      constraintName="fk_am_article"/>
    <addForeignKeyConstraint
      baseTableName="tbl_article_marker"
      baseColumnNames="marker_id"
      referencedTableName="tbl_marker"
      referencedColumnNames="id"
      constraintName="fk_am_marker"/>
  </changeSet>

</databaseChangeLog>