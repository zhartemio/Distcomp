<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

    <changeSet id="1" author="student">
        <createTable tableName="tbl_writer">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="login" type="varchar(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password" type="varchar(128)">
                <constraints nullable="false"/>
            </column>
            <column name="firstname" type="varchar(64)"/>
            <column name="lastname" type="varchar(64)"/>
            <column name="role" type="varchar(16)" defaultValue="USER">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="tbl_issue">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="writer_id" type="bigint">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="varchar(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="content" type="varchar(2048)"/>
            <column name="created" type="timestamp"/>
            <column name="modified" type="timestamp"/>
        </createTable>

        <createTable tableName="tbl_marker">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="varchar(32)"/>
        </createTable>

        <createTable tableName="tbl_issue_marker">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="issue_id" type="bigint"/>
            <column name="marker_id" type="bigint"/>
        </createTable>

        <insert tableName="tbl_writer">
            <column name="login" value="fcvlad2005@gmail.com"/>
            <column name="password" value="password"/>
            <column name="firstname" value="Vladislav"/>
            <column name="lastname" value="Student"/>
            <column name="role" value="ADMIN"/>
        </insert>
    </changeSet>
</databaseChangeLog>
