<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd">

    <changeSet id="001-create-tables" author="dima">

        <createTable tableName="tbl_user">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="login" type="VARCHAR(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>
            <column name="firstname" type="VARCHAR(64)"/>
            <column name="lastname" type="VARCHAR(64)"/>
            <column name="created" type="TIMESTAMP WITHOUT TIME ZONE"/>
            <column name="modified" type="TIMESTAMP WITHOUT TIME ZONE"/>
        </createTable>

        <createTable tableName="tbl_article">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="VARCHAR(2048)"/>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMP WITHOUT TIME ZONE"/>
            <column name="modified" type="TIMESTAMP WITHOUT TIME ZONE"/>
        </createTable>

        <createTable tableName="tbl_marker">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMP WITHOUT TIME ZONE"/>
            <column name="modified" type="TIMESTAMP WITHOUT TIME ZONE"/>
        </createTable>

        <createTable tableName="tbl_comment">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="text" type="VARCHAR(2048)"/>
            <column name="article_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMP WITHOUT TIME ZONE"/>
            <column name="modified" type="TIMESTAMP WITHOUT TIME ZONE"/>
        </createTable>

        <createTable tableName="tbl_article_marker">
            <column name="article_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="marker_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="tbl_article"
                baseColumnNames="user_id"
                constraintName="fk_article_user"
                referencedTableName="tbl_user"
                referencedColumnNames="id"
        />

        <addForeignKeyConstraint
                baseTableName="tbl_comment"
                baseColumnNames="article_id"
                constraintName="fk_comment_article"
                referencedTableName="tbl_article"
                referencedColumnNames="id"
        />

        <addForeignKeyConstraint
                baseTableName="tbl_article_marker"
                baseColumnNames="article_id"
                constraintName="fk_article_marker_article"
                referencedTableName="tbl_article"
                referencedColumnNames="id"
        />

        <addForeignKeyConstraint
                baseTableName="tbl_article_marker"
                baseColumnNames="marker_id"
                constraintName="fk_article_marker_marker"
                referencedTableName="tbl_marker"
                referencedColumnNames="id"
        />

    </changeSet>

</databaseChangeLog>