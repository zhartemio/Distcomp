<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-schema" author="codex">
        <sql>CREATE SCHEMA IF NOT EXISTS distcomp;</sql>
    </changeSet>

    <changeSet id="002-create-writer" author="codex">
        <createTable schemaName="distcomp" tableName="tbl_writer">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="login" type="VARCHAR(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>
            <column name="firstname" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="lastname" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="003-create-tag" author="codex">
        <createTable schemaName="distcomp" tableName="tbl_tag">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(32)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="004-create-story" author="codex">
        <createTable schemaName="distcomp" tableName="tbl_story">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="writer_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="VARCHAR(2048)">
                <constraints nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMP"/>
            <column name="modified" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableSchemaName="distcomp"
                                 baseTableName="tbl_story"
                                 baseColumnNames="writer_id"
                                 referencedTableSchemaName="distcomp"
                                 referencedTableName="tbl_writer"
                                 referencedColumnNames="id"
                                 constraintName="fk_story_writer"/>
    </changeSet>

    <changeSet id="005-create-post" author="codex">
        <createTable schemaName="distcomp" tableName="tbl_post">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="story_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="VARCHAR(2048)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableSchemaName="distcomp"
                                 baseTableName="tbl_post"
                                 baseColumnNames="story_id"
                                 referencedTableSchemaName="distcomp"
                                 referencedTableName="tbl_story"
                                 referencedColumnNames="id"
                                 constraintName="fk_post_story"/>
    </changeSet>

    <changeSet id="006-create-story-tag-link" author="codex">
        <createTable schemaName="distcomp" tableName="tbl_story_tag">
            <column name="story_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="tag_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="tbl_story_tag"
                       schemaName="distcomp"
                       columnNames="story_id, tag_id"
                       constraintName="pk_tbl_story_tag"/>
        <addForeignKeyConstraint baseTableSchemaName="distcomp"
                                 baseTableName="tbl_story_tag"
                                 baseColumnNames="story_id"
                                 referencedTableSchemaName="distcomp"
                                 referencedTableName="tbl_story"
                                 referencedColumnNames="id"
                                 constraintName="fk_story_tag_story"/>
        <addForeignKeyConstraint baseTableSchemaName="distcomp"
                                 baseTableName="tbl_story_tag"
                                 baseColumnNames="tag_id"
                                 referencedTableSchemaName="distcomp"
                                 referencedTableName="tbl_tag"
                                 referencedColumnNames="id"
                                 constraintName="fk_story_tag_tag"/>
    </changeSet>

</databaseChangeLog>
