{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "CassandraConnection": "jdbc:cassandra://localhost:9042/distcompcasssandra",
    "RedisConnection": "localhost:6379,abortConnect=false"
  },
  "Kafka": {
    "Enabled": false,
    "BootstrapServers": "localhost:9092",
    "InTopic": "InTopic",
    "OutTopic": "OutTopic"
  },
  "Redis": {
    "DefaultExpirationMinutes": 5,
    "NotesCachePrefix": "note:",
    "NotesListCacheKey": "notes:all"
  }
}
