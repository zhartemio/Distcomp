<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="1" author="distcomp">
        <sql>
            CREATE SCHEMA IF NOT EXISTS distcomp;
        </sql>
    </changeSet>

    <changeSet id="2" author="distcomp">
        <createTable tableName="tbl_creator" schemaName="distcomp">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="login" type="VARCHAR(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password" type="VARCHAR(128)">
                <constraints nullable="false"/>
            </column>
            <column name="firstname" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="lastname" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="modified" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="3" author="distcomp">
        <createTable tableName="tbl_marker" schemaName="distcomp">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(32)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="created" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="modified" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="4" author="distcomp">
        <createTable tableName="tbl_tweet" schemaName="distcomp">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="creator_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="VARCHAR(2048)">
                <constraints nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="modified" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_tweet_creator"
                baseTableName="tbl_tweet" baseTableSchema="distcomp"
                baseColumnNames="creator_id"
                referencedTableName="tbl_creator" referencedTableSchema="distcomp"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="5" author="distcomp">
        <createTable tableName="tbl_note" schemaName="distcomp">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tweet_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="content" type="VARCHAR(2048)">
                <constraints nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="modified" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_note_tweet"
                baseTableName="tbl_note" baseTableSchema="distcomp"
                baseColumnNames="tweet_id"
                referencedTableName="tbl_tweet" referencedTableSchema="distcomp"
                referencedColumnNames="id"
                onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="6" author="distcomp">
        <createTable tableName="tbl_tweet_marker" schemaName="distcomp">
            <column name="tweet_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="marker_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                constraintName="fk_tweet_marker_tweet"
                baseTableName="tbl_tweet_marker" baseTableSchema="distcomp"
                baseColumnNames="tweet_id"
                referencedTableName="tbl_tweet" referencedTableSchema="distcomp"
                referencedColumnNames="id"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                constraintName="fk_tweet_marker_marker"
                baseTableName="tbl_tweet_marker" baseTableSchema="distcomp"
                baseColumnNames="marker_id"
                referencedTableName="tbl_marker" referencedTableSchema="distcomp"
                referencedColumnNames="id"
                onDelete="CASCADE"/>

        <addPrimaryKey
                constraintName="pk_tweet_marker"
                tableName="tbl_tweet_marker" schemaName="distcomp"
                columnNames="tweet_id, marker_id"/>
    </changeSet>

    <changeSet id="7" author="distcomp">
        <insert schemaName="distcomp" tableName="tbl_creator">
            <column name="login" value="dioxys@tut.by"/>
            <column name="password" value="password123"/>
            <column name="firstname" value="Даниил"/>
            <column name="lastname" value="Машевский"/>
            <column name="created" valueComputed="CURRENT_TIMESTAMP"/>
            <column name="modified" valueComputed="CURRENT_TIMESTAMP"/>
        </insert>
    </changeSet>
</databaseChangeLog>